{
  "name": "enshrouded-server-config",
  "version": "1.0.0",
  "type": "module",
  "description": "Enshrouded game server configuration tool built with Valence",
  "scripts": {
    "dev": "tsx --watch server.ts",
    "build": "tsc",
    "migrate": "valence migrate",
    "user:create": "valence user:create",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@valencets/cms": "link:../dev/valence/packages/cms",
    "@valencets/core": "link:../dev/valence/packages/core",
    "@valencets/db": "link:../dev/valence/packages/db",
    "@valencets/telemetry": "link:../dev/valence/packages/telemetry",
    "@valencets/ui": "link:../dev/valence/packages/ui",
    "@valencets/valence": "link:../dev/valence/packages/valence",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
